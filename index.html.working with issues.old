<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>APEX — Market Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500;700&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #06080f;
  --bg2:     #0a0d18;
  --bg3:     #0f1322;
  --bg4:     #151b2e;
  --border:  rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.14);
  --accent:  #00ffd0;
  --accent2: #0066ff;
  --warn:    #ffb800;
  --danger:  #ff3355;
  --text:    #e2eaf5;
  --text2:   #6b7f99;
  --text3:   #2e3f55;
  --up:      #00ffd0;
  --down:    #ff3355;
  --card:    rgba(255,255,255,0.03);
  --radius:  12px;
  --radius-sm: 8px;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html { font-size: 16px; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Mulish', sans-serif;
  min-height: 100vh;
  min-height: 100dvh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* Background texture */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(0,255,208,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,208,0.02) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events:none;
  z-index:0;
}

/* ── LAYOUT ────────────────────────────────── */
.app {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
  height: 100dvh;
  overflow: hidden;
}

/* ── TOPBAR ────────────────────────────────── */
.topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  z-index: 10;
}

.logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  letter-spacing: 3px;
  color: var(--accent);
  text-shadow: 0 0 20px rgba(0,255,208,0.4);
  flex-shrink: 0;
}

/* Search */
.search-wrap {
  flex: 1;
  position: relative;
  max-width: 400px;
}

.search-input {
  width: 100%;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 14px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  color: var(--text);
  outline: none;
  transition: all 0.2s;
}

.search-input::placeholder { color: var(--text3); }
.search-input:focus { border-color: rgba(0,255,208,0.3); background: var(--bg4); }

.search-results {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  z-index: 100;
  overflow: hidden;
  display: none;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  max-height: 300px;
  overflow-y: auto;
}

.search-results.open { display: block; }

.search-result-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  cursor: pointer;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}

.search-result-item:last-child { border-bottom: none; }
.search-result-item:hover, .search-result-item:active { background: rgba(0,255,208,0.05); }

.sri-ticker { font-family:'IBM Plex Mono',monospace; font-size:12px; font-weight:700; color:var(--accent); min-width:50px; }
.sri-name { font-size:12px; color:var(--text2); flex:1; }
.search-loading { padding:12px 14px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--accent); }
.search-no-result { padding:12px 14px; font-size:11px; color:var(--text3); }

/* Scan button */
.scan-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  background: var(--accent);
  color: var(--bg);
  border: none;
  border-radius: var(--radius-sm);
  font-family: 'Bebas Neue', sans-serif;
  font-size: 16px;
  letter-spacing: 1px;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.2s;
  white-space: nowrap;
}

.scan-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.scan-btn:active { transform: translateY(0); }
.scan-btn.scanning { background: var(--bg3); color: var(--accent); border: 1px solid var(--accent); }

/* ── TABS ──────────────────────────────────── */
.tabs {
  display: flex;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.tabs::-webkit-scrollbar { display: none; }

.tab {
  flex: 1;
  min-width: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px 16px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  color: var(--text3);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  white-space: nowrap;
  text-transform: uppercase;
}

.tab:hover { color: var(--text2); }
.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.tab-count {
  background: var(--bg3);
  color: var(--text2);
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 10px;
  font-family: 'IBM Plex Mono', monospace;
}
.tab.active .tab-count { background: rgba(0,255,208,0.15); color: var(--accent); }

/* ── MAIN CONTENT ──────────────────────────── */
.main-content {
  flex: 1;
  overflow: hidden;
  display: flex;
  position: relative;
}

/* Desktop: side by side */
@media (min-width: 768px) {
  .main-content { flex-direction: row; }
  .stock-list { border-right: 1px solid var(--border); width: 380px; flex-shrink: 0; }
  .detail-panel { flex: 1; }
}

/* Mobile: stacked */
@media (max-width: 767px) {
  .main-content { flex-direction: column; }
  .stock-list { flex: 1; overflow-y: auto; }
  .detail-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 70vh;
    background: var(--bg2);
    border-top: 1px solid var(--border2);
    border-radius: 20px 20px 0 0;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 50;
    overflow-y: auto;
  }
  .detail-panel.open { transform: translateY(0); }
  .detail-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 49;
    display: none;
  }
  .detail-overlay.open { display: block; }
}

/* ── STOCK LIST ────────────────────────────── */
.stock-list {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

.stock-list::-webkit-scrollbar { width: 3px; }
.stock-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  min-height: 300px;
  gap: 12px;
  padding: 40px 20px;
  text-align: center;
}

.empty-icon { font-size: 48px; opacity: 0.4; }
.empty-title { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 2px; color: var(--text2); }
.empty-desc { font-size: 13px; color: var(--text3); line-height: 1.6; max-width: 260px; }

/* Loading state */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  gap: 16px;
}

.spinner {
  width: 32px; height: 32px;
  border: 2px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 2px;
  animation: pulse 1.5s infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ── STOCK CARD ────────────────────────────── */
.stock-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.15s;
  animation: fadeUp 0.3s ease both;
  position: relative;
}

.stock-card:active, .stock-card:hover { background: rgba(255,255,255,0.02); }
.stock-card.selected { background: rgba(0,255,208,0.04); border-left: 2px solid var(--accent); padding-left: 14px; }

/* Hot badge on left */
.card-heat {
  width: 4px;
  border-radius: 2px;
  align-self: stretch;
  flex-shrink: 0;
}

.card-heat.both { background: var(--accent); box-shadow: 0 0 8px rgba(0,255,208,0.4); }
.card-heat.finnhub { background: var(--accent2); }
.card-heat.reddit { background: #ff6b35; }
.card-heat.watch { background: var(--warn); }
.card-heat.owned { background: var(--accent); }

.card-main { flex: 1; min-width: 0; }

.card-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 3px;
}

.card-ticker {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  letter-spacing: 1px;
  line-height: 1;
}

.card-badge {
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 3px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.badge-both { background: rgba(0,255,208,0.1); color: var(--accent); border: 1px solid rgba(0,255,208,0.2); }
.badge-finnhub { background: rgba(0,102,255,0.1); color: #4d94ff; border: 1px solid rgba(0,102,255,0.2); }
.badge-reddit { background: rgba(255,107,53,0.1); color: #ff6b35; border: 1px solid rgba(255,107,53,0.2); }
.badge-watch { background: rgba(255,184,0,0.1); color: var(--warn); border: 1px solid rgba(255,184,0,0.2); }
.badge-owned { background: rgba(0,255,208,0.1); color: var(--accent); border: 1px solid rgba(0,255,208,0.2); }

.card-name { font-size: 12px; color: var(--text2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-reason { font-size: 11px; color: var(--text3); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.card-right { text-align: right; flex-shrink: 0; }
.card-price { font-family: 'IBM Plex Mono', monospace; font-size: 14px; font-weight: 700; }
.card-change {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  display: inline-block;
  padding: 2px 6px;
  border-radius: 4px;
  margin-top: 2px;
}
.card-change.up { background: rgba(0,255,208,0.1); color: var(--up); }
.card-change.dn { background: rgba(255,51,85,0.1); color: var(--down); }

/* P&L for owned stocks */
.card-pnl {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  margin-top: 2px;
}
.card-pnl.up { color: var(--up); }
.card-pnl.dn { color: var(--down); }

/* ── DETAIL PANEL ───────────────────────────── */
.detail-panel {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background: var(--bg2);
}

/* Mobile drag handle */
.drag-handle {
  display: none;
  width: 40px;
  height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 12px auto 8px;
}

@media (max-width: 767px) {
  .drag-handle { display: block; }
  .detail-close {
    position: absolute;
    top: 12px;
    right: 16px;
    width: 32px;
    height: 32px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    color: var(--text2);
  }
}

@media (min-width: 768px) {
  .detail-close { display: none; }
}

.detail-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 12px;
  opacity: 0.3;
}

.detail-empty-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px;
  letter-spacing: 6px;
  color: var(--accent);
}

.detail-empty-text {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 2px;
}

/* Detail content */
.detail-header {
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--border);
}

.detail-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.detail-left { display: flex; align-items: center; gap: 12px; }

.detail-logo {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  object-fit: contain;
  background: white;
  padding: 2px;
  flex-shrink: 0;
}

.detail-ticker-block {}
.detail-ticker {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  letter-spacing: 2px;
  line-height: 1;
}
.detail-name { font-size: 12px; color: var(--text2); margin-top: 2px; }

.detail-price-block { text-align: right; }
.detail-price { font-family: 'IBM Plex Mono', monospace; font-size: 24px; font-weight: 700; }
.detail-change-badge {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 5px;
  display: inline-block;
  margin-top: 3px;
}

.detail-meta {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.meta-pill {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  color: var(--text3);
  background: var(--bg3);
  padding: 3px 8px;
  border-radius: 4px;
  border: 1px solid var(--border);
}

/* AI Advice box */
.ai-advice-box {
  margin: 16px 20px;
  background: rgba(0,255,208,0.04);
  border: 1px solid rgba(0,255,208,0.15);
  border-radius: var(--radius);
  padding: 14px 16px;
}

.ai-advice-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.ai-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.ai-verdict {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 2px;
  padding: 3px 10px;
  border-radius: 4px;
}

.verdict-buy { background: rgba(0,255,208,0.15); color: var(--up); }
.verdict-monitor { background: rgba(255,184,0,0.15); color: var(--warn); }
.verdict-avoid { background: rgba(255,51,85,0.15); color: var(--down); }
.verdict-sell { background: rgba(255,51,85,0.2); color: var(--down); }

.ai-text { font-size: 13px; color: var(--text2); line-height: 1.6; }

.ai-get-btn {
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1px solid rgba(0,255,208,0.2);
  border-radius: var(--radius-sm);
  color: var(--accent);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 1px;
}

.ai-get-btn:hover, .ai-get-btn:active { background: rgba(0,255,208,0.08); }

/* Score section */
.score-section {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
}

.section-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.score-total {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  letter-spacing: 2px;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255,255,255,0.03);
}

.score-row:last-child { border-bottom: none; }
.score-source { font-size: 11px; color: var(--text2); flex: 1; }
.score-detail { font-size: 10px; color: var(--text3); font-family: 'IBM Plex Mono', monospace; }
.score-track { width: 60px; height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; flex-shrink: 0; }
.score-fill { height: 100%; border-radius: 2px; }
.score-pts { font-family: 'IBM Plex Mono', monospace; font-size: 10px; font-weight: 700; width: 32px; text-align: right; flex-shrink: 0; }

/* Catalyst section */
.catalyst-section {
  padding: 14px 20px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,184,0,0.03);
}

.catalyst-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.catalyst-icon { font-size: 20px; }
.catalyst-info {}
.catalyst-date { font-size: 13px; font-weight: 600; color: var(--warn); }
.catalyst-urgency { font-size: 11px; color: var(--text3); margin-top: 2px; }

/* News section */
.news-section { padding: 14px 20px; }

.news-item {
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
}

.news-item:last-child { border-bottom: none; }
.news-item:active { opacity: 0.7; }

.news-meta { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.news-time { font-family: 'IBM Plex Mono', monospace; font-size: 9px; color: var(--text3); }
.news-sent { font-size: 9px; font-weight: 700; padding: 1px 5px; border-radius: 3px; }
.news-sent.pos { background: rgba(0,255,208,0.1); color: var(--up); }
.news-sent.neg { background: rgba(255,51,85,0.1); color: var(--down); }
.news-sent.neu { background: rgba(107,127,153,0.1); color: var(--text2); }
.news-headline { font-size: 12px; line-height: 1.5; color: var(--text); }

/* ── MY STOCKS — Add form ───────────────────── */
.add-stock-bar {
  display: flex;
  gap: 8px;
  padding: 12px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}

.add-input {
  flex: 1;
  min-width: 80px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  color: var(--text);
  outline: none;
}

.add-input::placeholder { color: var(--text3); font-size: 11px; }
.add-input:focus { border-color: rgba(0,255,208,0.3); }

.add-btn {
  padding: 8px 14px;
  background: var(--accent);
  color: var(--bg);
  border: none;
  border-radius: var(--radius-sm);
  font-family: 'Bebas Neue', sans-serif;
  font-size: 16px;
  letter-spacing: 1px;
  cursor: pointer;
  flex-shrink: 0;
}

/* P&L summary bar */
.pnl-bar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.pnl-cell {
  background: var(--bg2);
  padding: 10px 16px;
  text-align: center;
}

.pnl-label { font-size: 9px; color: var(--text3); font-family: 'IBM Plex Mono', monospace; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px; }
.pnl-value { font-family: 'IBM Plex Mono', monospace; font-size: 14px; font-weight: 700; }

/* ── DISCOVERY SCAN RESULTS ─────────────────── */
.scan-summary {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  font-size: 11px;
  color: var(--text3);
  font-family: 'IBM Plex Mono', monospace;
  flex-shrink: 0;
}

.scan-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 6px var(--accent); animation: pulse 2s infinite; flex-shrink: 0; }

.legend { display: flex; gap: 10px; margin-left: auto; flex-wrap: wrap; }
.legend-item { display: flex; align-items: center; gap: 4px; font-size: 9px; }
.legend-dot { width: 6px; height: 6px; border-radius: 50%; }

/* ── SCROLLBAR ──────────────────────────────── */
::-webkit-scrollbar { width: 3px; height: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
</head>
<body>
<div class="app">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="logo">APEX</div>
    <div class="search-wrap">
      <input type="text" id="searchInput" class="search-input" 
             placeholder="Search any stock..." 
             autocomplete="off"
             oninput="onSearchInput(this.value)"
             onkeydown="onSearchKey(event)"/>
      <div class="search-results" id="searchResults"></div>
    </div>
    <button class="scan-btn" id="scanBtn" onclick="startScan()">🔥 SCAN</button>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" id="tab-discovery" onclick="switchTab('discovery')">
      🔥 Discovery
      <span class="tab-count" id="cnt-discovery">0</span>
    </div>
    <div class="tab" id="tab-mystocks" onclick="switchTab('mystocks')">
      💼 My Stocks
      <span class="tab-count" id="cnt-mystocks">0</span>
    </div>
    <div class="tab" id="tab-watchlist" onclick="switchTab('watchlist')">
      👁 Watchlist
      <span class="tab-count" id="cnt-watchlist">0</span>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main-content">

    <!-- STOCK LIST -->
    <div class="stock-list" id="stockList">
      <div class="empty-state">
        <div class="empty-icon">🔥</div>
        <div class="empty-title">Ready to Scan</div>
        <div class="empty-desc">Press SCAN to discover hot stocks from Finnhub and Reddit, or search for any stock above.</div>
      </div>
    </div>

    <!-- DETAIL PANEL -->
    <div class="detail-panel" id="detailPanel">
      <div class="drag-handle"></div>
      <div class="detail-close" onclick="closeDetail()">✕</div>
      <div class="detail-empty">
        <div class="detail-empty-logo">APEX</div>
        <div class="detail-empty-text">TAP A STOCK TO ANALYSE</div>
      </div>
    </div>

    <!-- Mobile overlay -->
    <div class="detail-overlay" id="detailOverlay" onclick="closeDetail()"></div>

  </div>
</div>

<script>
// ── STATE ──────────────────────────────────────────────────────────────────────
let currentTab = 'discovery';
let selectedTicker = null;
let discoveryResults = [];
let searchTimeout = null;

// Persistent data
let myStocks = JSON.parse(localStorage.getItem('apexMyStocks') || '[]');
let watchlist = JSON.parse(localStorage.getItem('apexWatchlist') || '[]');

// ── TABS ───────────────────────────────────────────────────────────────────────
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');

  if(tab === 'discovery') renderDiscovery();
  else if(tab === 'mystocks') renderMyStocks();
  else if(tab === 'watchlist') renderWatchlist();
}

function updateCounts() {
  document.getElementById('cnt-discovery').textContent = discoveryResults.length;
  document.getElementById('cnt-mystocks').textContent = myStocks.length;
  document.getElementById('cnt-watchlist').textContent = watchlist.length;
}

// ── SEARCH ─────────────────────────────────────────────────────────────────────
function onSearchInput(val) {
  clearTimeout(searchTimeout);
  const q = val.trim();
  const el = document.getElementById('searchResults');
  if(q.length < 2) { el.classList.remove('open'); return; }

  el.innerHTML = `<div class="search-loading">⬡ Searching...</div>`;
  el.classList.add('open');

  searchTimeout = setTimeout(async () => {
    try {
      const res = await fetch(`/finnhub?type=search&query=${encodeURIComponent(q)}`);
      const data = await res.json();
      if(!data.result || data.result.length === 0) {
        el.innerHTML = `<div class="search-no-result">No results for "${q}"</div>`;
        return;
      }
      const stocks = data.result.filter(r => r.type === 'Common Stock').slice(0, 6);
      el.innerHTML = stocks.map(s => `
        <div class="search-result-item" onclick="loadStock('${s.symbol}','${s.description.replace(/'/g,"\\'")}')">
          <div class="sri-ticker">${s.displaySymbol}</div>
          <div class="sri-name">${s.description}</div>
        </div>`).join('');
    } catch(e) {
      el.innerHTML = `<div class="search-no-result">Search failed</div>`;
    }
  }, 400);
}

function onSearchKey(e) {
  if(e.key === 'Escape') {
    document.getElementById('searchResults').classList.remove('open');
    document.getElementById('searchInput').value = '';
  }
}

document.addEventListener('click', e => {
  if(!e.target.closest('.search-wrap')) {
    document.getElementById('searchResults').classList.remove('open');
  }
});

// ── FETCH HELPERS ──────────────────────────────────────────────────────────────
async function fetchQuote(symbol) {
  try {
    const res = await fetch(`/finnhub?type=quote&symbol=${symbol}`);
    return await res.json();
  } catch { return null; }
}

async function fetchNews(symbol) {
  try {
    const res = await fetch(`/finnhub?type=news&symbol=${symbol}`);
    const data = await res.json();
    if(!Array.isArray(data)) return [];
    return data.slice(0,4).map(n => {
      const hl = (n.headline||'').toLowerCase();
      const pos = ['surge','beat','win','rise','jump','strong','record','approval','growth','gain','upgrade','rally'];
      const neg = ['fall','drop','miss','decline','cut','loss','crash','disappoint','concern','risk','downgrade','warn'];
      const s = pos.some(w=>hl.includes(w)) ? 'pos' : neg.some(w=>hl.includes(w)) ? 'neg' : 'neu';
      const ago = Math.round((Date.now()/1000 - n.datetime)/3600);
      const t = ago < 1 ? 'Just now' : ago === 1 ? '1h ago' : ago < 24 ? ago+'h ago' : Math.round(ago/24)+'d ago';
      return { t, s, h: n.headline };
    });
  } catch { return []; }
}

async function fetchEarnings(symbol) {
  try {
    const res = await fetch(`/finnhub?type=earnings&symbol=${symbol}`);
    const data = await res.json();
    if(!data.earningsCalendar || data.earningsCalendar.length === 0) return null;
    const next = data.earningsCalendar[0];
    const days = Math.ceil((new Date(next.date) - new Date()) / (1000*60*60*24));
    return { date: next.date, days, quarter: next.quarter, year: next.year };
  } catch { return null; }
}

async function fetchAnalyst(symbol) {
  try {
    const res = await fetch(`/finnhub?type=analyst&symbol=${symbol}`);
    const data = await res.json();
    if(!Array.isArray(data) || data.length === 0) return null;
    const latest = data[0];
    const total = latest.strongBuy + latest.buy + latest.hold + latest.sell + latest.strongSell;
    if(total === 0) return null;
    const bullish = latest.strongBuy + latest.buy;
    const bullishPct = Math.round((bullish/total)*100);
    return { bullishPct, total, strongBuy: latest.strongBuy, buy: latest.buy, hold: latest.hold, sell: latest.sell };
  } catch { return null; }
}

async function fetchProfile(symbol) {
  try {
    const res = await fetch(`/finnhub?type=profile&symbol=${symbol}`);
    return await res.json();
  } catch { return null; }
}

function formatMarketCap(mc) {
  if(mc >= 1000000) return `$${(mc/1000000).toFixed(2)}T`;
  if(mc >= 1000) return `$${(mc/1000).toFixed(1)}B`;
  return `$${mc.toFixed(0)}M`;
}

function calcScore(quote, earnings, analyst, news) {
  let catalyst = 5, analystScore = 10, newsScore = 8, volatility = 5;

  if(earnings) {
    catalyst = earnings.days <= 1 ? 29 : earnings.days <= 3 ? 25 : earnings.days <= 7 ? 20 : earnings.days <= 14 ? 15 : earnings.days <= 30 ? 10 : 5;
  }

  if(analyst) {
    analystScore = analyst.bullishPct >= 75 ? 19 : analyst.bullishPct >= 60 ? 16 : analyst.bullishPct >= 50 ? 13 : analyst.bullishPct >= 40 ? 9 : 5;
  }

  if(news && news.length > 0) {
    const pos = news.filter(n=>n.s==='pos').length;
    const neg = news.filter(n=>n.s==='neg').length;
    newsScore = pos > neg ? Math.min(20, 12 + pos*2) : Math.max(3, 10 - neg*2);
  }

  if(quote) {
    const change = Math.abs(quote.dp||0);
    volatility = change > 5 ? 14 : change > 3 ? 11 : change > 1 ? 8 : 5;
  }

  return { catalyst, analyst: analystScore, news: newsScore, volatility, total: catalyst + analystScore + newsScore + volatility };
}

// ── DISCOVERY SCAN ─────────────────────────────────────────────────────────────

// S&P 500 sample universe — easily expandable
const SP500_SAMPLE = [
  'AAPL','MSFT','NVDA','GOOGL','AMZN','META','TSLA','BRK.B','AVGO','JPM',
  'LLY','V','UNH','XOM','MA','JNJ','PG','HD','MRK','ABBV',
  'COST','ORCL','BAC','CRM','CVX','AMD','MCD','NFLX','TMO','PEP',
  'ADBE','LIN','CSCO','WMT','ACN','DIS','TXN','ABT','AMGN','DHR',
  'CAT','NEE','QCOM','GS','RTX','SPGI','BLK','ISRG','PFE','INTU',
  'MRNA','PLTR','SHOP','UBER','COIN','SQ','RIVN','SNAP','SPOT','RBLX',
  'CRSP','BEAM','RXRX','NTLA','REGN','VRTX','ENPH','FSLR','NKE','SBUX',
  'PYPL','AFRM','SOFI','HOOD','DAVE','SOUN','LCID','NIO','ARM','SMCI'
];

async function startScan() {
  const btn = document.getElementById('scanBtn');
  btn.classList.add('scanning');
  btn.textContent = '⟳ SCANNING...';

  switchTab('discovery');
  document.getElementById('stockList').innerHTML = `
    <div class="loading-state">
      <div class="spinner"></div>
      <div class="loading-text">SCANNING MARKETS...</div>
    </div>`;

  try {
    // Step 1: Get market movers from Finnhub
    const finnhubHot = await scanFinnhub();

    // Step 2: Get Reddit trending
    const redditHot = await scanReddit();

    // Step 3: Cross reference
    const results = crossReference(finnhubHot, redditHot);

    discoveryResults = results;
    updateCounts();
    renderDiscovery();

  } catch(e) {
    console.error('Scan error:', e);
    document.getElementById('stockList').innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">⚠️</div>
        <div class="empty-title">Scan Failed</div>
        <div class="empty-desc">Check your connection and try again.</div>
      </div>`;
  }

  btn.classList.remove('scanning');
  btn.textContent = '🔥 SCAN';
}

async function scanFinnhub() {
  const hot = new Map();

  // Fetch quotes for sample universe in batches
  const batch = SP500_SAMPLE.slice(0, 40);
  const quotes = await Promise.allSettled(
    batch.map(async sym => {
      const q = await fetchQuote(sym);
      return { sym, q };
    })
  );

  quotes.forEach(r => {
    if(r.status === 'fulfilled' && r.value.q && r.value.q.c > 0) {
      const { sym, q } = r.value;
      const absChange = Math.abs(q.dp || 0);
      if(absChange > 2) { // Only stocks moving more than 2%
        hot.set(sym, {
          ticker: sym,
          price: q.c,
          change: q.dp,
          reason: `${q.dp > 0 ? '+' : ''}${q.dp.toFixed(2)}% today`,
          source: 'finnhub',
          score: absChange
        });
      }
    }
  });

  return hot;
}

async function scanReddit() {
  const hot = new Map();

  try {
    // Fetch trending from r/wallstreetbets and r/stocks
    const [wsb, stocks] = await Promise.allSettled([
      fetch('/finnhub?type=reddit-wsb').then(r=>r.json()),
      fetch('/finnhub?type=reddit-stocks').then(r=>r.json())
    ]);

    const posts = [];
    if(wsb.status === 'fulfilled') posts.push(...(wsb.value?.data?.children||[]));
    if(stocks.status === 'fulfilled') posts.push(...(stocks.value?.data?.children||[]));

    // Extract tickers from post titles
    // Match both $TICKER and plain TICKER formats
    const dollarRegex = /\$([A-Z]{1,5})\b/g;
    const plainRegex = /\b(INTC|AAPL|MSFT|NVDA|TSLA|META|AMZN|GOOGL|AMD|PLTR|MRNA|GME|AMC|SPY|QQQ|COIN|HOOD|SOFI|RIVN|NIO|ARM|SMCI|TXN|CRM|ADBE|ORCL|JPM|BAC|GS|MS|TMO|ENPH|FSLR|UBER|SHOP|PYPL|AFRM|NFLX|DIS|SNAP|RBLX|SPOT|LLY|PFE|ABBV|REGN|VRTX|CRSP|BEAM|RXRX)\b/g;
    const mentions = new Map();

    posts.forEach(post => {
      const title = post?.data?.title || '';
      const text = post?.data?.selftext || '';
      const content = title + ' ' + text;
      let match;
  // Catch $TICKER format
  while((match = dollarRegex.exec(content)) !== null) {
   const ticker = match[1];
   mentions.set(ticker, (mentions.get(ticker) || 0) + 2); // weight higher
}
// Catch plain TICKER format
while((match = plainRegex.exec(content)) !== null) {
  const ticker = match[1];
  mentions.set(ticker, (mentions.get(ticker) || 0) + 1);
}});

    // Only keep tickers mentioned 2+ times
    mentions.forEach((count, ticker) => {
      if(count >= 2) {
        hot.set(ticker, {
          ticker,
          price: 0,
          change: 0,
          reason: `Mentioned ${count}x on Reddit`,
          source: 'reddit',
          score: count,
          mentions: count
        });
      }
    });

  } catch(e) {
    console.log('Reddit scan failed:', e);
  }

  return hot;
}

function crossReference(finnhubHot, redditHot) {
  const results = [];
  const seen = new Set();

  // Stocks in BOTH — highest confidence
  finnhubHot.forEach((data, ticker) => {
    if(redditHot.has(ticker)) {
      const reddit = redditHot.get(ticker);
      results.push({
        ...data,
        source: 'both',
        reason: `${data.reason} · Reddit ${reddit.mentions}x`,
        confidence: 'both'
      });
      seen.add(ticker);
    }
  });

  // Finnhub only
  finnhubHot.forEach((data, ticker) => {
    if(!seen.has(ticker)) {
      results.push({ ...data, confidence: 'finnhub' });
      seen.add(ticker);
    }
  });

  // Reddit only — fetch prices
  redditHot.forEach((data, ticker) => {
    if(!seen.has(ticker) && SP500_SAMPLE.includes(ticker)) {
      results.push({ ...data, confidence: 'reddit' });
      seen.add(ticker);
    }
  });

  // Sort: both first, then by score
  results.sort((a,b) => {
    if(a.confidence === 'both' && b.confidence !== 'both') return -1;
    if(b.confidence === 'both' && a.confidence !== 'both') return 1;
    return b.score - a.score;
  });

  return results.slice(0, 20);
}

// ── RENDER DISCOVERY ───────────────────────────────────────────────────────────
function renderDiscovery() {
  const el = document.getElementById('stockList');

  if(discoveryResults.length === 0) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">🔥</div>
        <div class="empty-title">Ready to Scan</div>
        <div class="empty-desc">Press SCAN to discover hot stocks from Finnhub and Reddit.</div>
      </div>`;
    return;
  }

  const summary = `
    <div class="scan-summary">
      <div class="scan-dot"></div>
      <span>${discoveryResults.length} stocks found</span>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--accent)"></div>Both</div>
        <div class="legend-item"><div class="legend-dot" style="background:#4d94ff"></div>Finnhub</div>
        <div class="legend-item"><div class="legend-dot" style="background:#ff6b35"></div>Reddit</div>
      </div>
    </div>`;

  const cards = discoveryResults.map((s, i) => {
    const up = s.change >= 0;
    const badgeClass = `badge-${s.confidence}`;
    const badgeText = s.confidence === 'both' ? '🔥 HOT' : s.confidence === 'finnhub' ? 'FINNHUB' : 'REDDIT';
    const heatClass = `card-heat ${s.confidence}`;

    return `<div class="stock-card" id="card-${s.ticker}" onclick="selectStock('${s.ticker}','${s.confidence}')" style="animation-delay:${i*0.04}s">
      <div class="${heatClass}"></div>
      <div class="card-main">
        <div class="card-top">
          <div class="card-ticker">${s.ticker}</div>
          <div class="card-badge ${badgeClass}">${badgeText}</div>
        </div>
        <div class="card-name" id="name-${s.ticker}">Loading...</div>
        <div class="card-reason">${s.reason}</div>
      </div>
      <div class="card-right">
        ${s.price > 0 ? `<div class="card-price">$${s.price.toFixed(2)}</div>
        <div class="card-change ${up?'up':'dn'}">${up?'+':''}${s.change.toFixed(2)}%</div>` : '<div class="card-price" style="color:var(--text3)">—</div>'}
      </div>
    </div>`;
  }).join('');

  el.innerHTML = summary + cards;

  // Load company names in background
  discoveryResults.forEach(s => loadCompanyName(s.ticker));

  // Fetch prices for Reddit-only stocks
  discoveryResults.filter(s => s.confidence === 'reddit' && s.price === 0).forEach(async s => {
    const q = await fetchQuote(s.ticker);
    if(q && q.c > 0) {
      s.price = q.c;
      s.change = q.dp;
      const card = document.getElementById('card-' + s.ticker);
      if(card) {
        const right = card.querySelector('.card-right');
        const up = q.dp >= 0;
        right.innerHTML = `<div class="card-price">$${q.c.toFixed(2)}</div>
          <div class="card-change ${up?'up':'dn'}">${up?'+':''}${q.dp.toFixed(2)}%</div>`;
      }
    }
  });
}

async function loadCompanyName(ticker) {
  const el = document.getElementById('name-' + ticker);
  if(!el) return;

  // Check if we already know the name
  const known = [...myStocks, ...watchlist].find(s => s.ticker === ticker);
  if(known) { el.textContent = known.name; return; }

  try {
    const res = await fetch(`/finnhub?type=profile&symbol=${ticker}`);
    const data = await res.json();
    if(data.name && el) el.textContent = data.name;
    else if(el) el.textContent = ticker;
  } catch {
    if(el) el.textContent = ticker;
  }
}

// ── SELECT STOCK ───────────────────────────────────────────────────────────────
async function selectStock(ticker, source) {
  selectedTicker = ticker;

  // Highlight card
  document.querySelectorAll('.stock-card').forEach(c => c.classList.remove('selected'));
  const card = document.getElementById('card-' + ticker);
  if(card) card.classList.add('selected');

  // Open detail panel
  openDetail();

  // Show loading
  const panel = document.getElementById('detailPanel');
  panel.innerHTML = `
    <div class="drag-handle"></div>
    <div class="detail-close" onclick="closeDetail()">✕</div>
    <div class="loading-state" style="height:300px">
      <div class="spinner"></div>
      <div class="loading-text">LOADING ${ticker}...</div>
    </div>`;

  // Fetch all data in parallel
  const [quote, profile, earnings, analyst, news] = await Promise.all([
    fetchQuote(ticker),
    fetchProfile(ticker),
    fetchEarnings(ticker),
    fetchAnalyst(ticker),
    fetchNews(ticker)
  ]);

  if(selectedTicker !== ticker) return;

  // Calculate scores
  const scores = calcScore(quote, earnings, analyst, news);
  const up = (quote?.dp || 0) >= 0;
  const price = quote?.c || 0;
  const change = quote?.dp || 0;

  // Score color
  const scoreColor = scores.total >= 60 ? 'var(--up)' : scores.total >= 40 ? 'var(--warn)' : 'var(--down)';

  // Score rows
  const scoreRows = [
    { label:'Catalyst', pts:scores.catalyst, max:30, color:'var(--warn)', detail: earnings ? `${earnings.days}d to earnings` : 'No upcoming' },
    { label:'Analyst', pts:scores.analyst, max:20, color:'var(--accent)', detail: analyst ? `${analyst.bullishPct}% bullish — ${analyst.total} analysts` : 'No data' },
    { label:'News', pts:scores.news, max:20, color:'#c084fc', detail: scores.news >= 15 ? 'Positive' : scores.news >= 10 ? 'Mixed' : 'Negative' },
    { label:'Volatility', pts:scores.volatility, max:15, color:'#4da6ff', detail: `${Math.abs(change).toFixed(2)}% move today` },
    { label:'Social', pts:0, max:15, color:'#f472b6', detail: '⏳ Reddit coming soon' },
  ];

  // Check if owned
  const owned = myStocks.find(s => s.ticker === ticker);
  const inWatchlist = watchlist.find(s => s.ticker === ticker);

  panel.innerHTML = `
    <div class="drag-handle"></div>
    <div class="detail-close" onclick="closeDetail()">✕</div>

    <!-- Header -->
    <div class="detail-header">
      <div class="detail-top">
        <div class="detail-left">
          ${profile?.logo ? `<img class="detail-logo" src="${profile.logo}" alt="${ticker}" onerror="this.style.display='none'">` : ''}
          <div class="detail-ticker-block">
            <div class="detail-ticker" style="color:${up?'var(--up)':'var(--down)'}">${ticker}</div>
            <div class="detail-name">${profile?.name || ticker}</div>
          </div>
        </div>
        <div class="detail-price-block">
          <div class="detail-price" style="color:${up?'var(--up)':'var(--down)'}">$${price.toFixed(2)}</div>
          <div class="detail-change-badge ${up?'up':'dn'}" style="background:${up?'rgba(0,255,208,0.1)':'rgba(255,51,85,0.1)'};color:${up?'var(--up)':'var(--down)'}">
            ${up?'+':''}${change.toFixed(2)}%
          </div>
        </div>
      </div>
      <div class="detail-meta">
        ${profile?.exchange ? `<span class="meta-pill">${profile.exchange}</span>` : ''}
        ${profile?.finnhubIndustry ? `<span class="meta-pill">${profile.finnhubIndustry}</span>` : ''}
        ${profile?.marketCapitalization ? `<span class="meta-pill">Cap: ${formatMarketCap(profile.marketCapitalization)}</span>` : ''}
        ${quote?.h ? `<span class="meta-pill">H: $${quote.h.toFixed(2)}</span>` : ''}
        ${quote?.l ? `<span class="meta-pill">L: $${quote.l.toFixed(2)}</span>` : ''}
      </div>
    </div>

    <!-- Action buttons -->
    <div style="display:flex;gap:8px;padding:12px 20px;border-bottom:1px solid var(--border)">
      ${!owned ? `<button onclick="addToMyStocks('${ticker}','${profile?.name||ticker}',${price})" 
        style="flex:1;padding:8px;background:rgba(0,255,208,0.08);border:1px solid rgba(0,255,208,0.2);border-radius:8px;color:var(--accent);font-family:'IBM Plex Mono',monospace;font-size:11px;cursor:pointer">
        + Add to My Stocks
      </button>` : `<div style="flex:1;padding:8px;background:rgba(0,255,208,0.04);border:1px solid rgba(0,255,208,0.1);border-radius:8px;color:var(--accent);font-family:'IBM Plex Mono',monospace;font-size:11px;text-align:center">
        💼 In My Stocks
      </div>`}
      ${!inWatchlist ? `<button onclick="addToWatchlist('${ticker}','${profile?.name||ticker}',${price})"
        style="flex:1;padding:8px;background:rgba(255,184,0,0.08);border:1px solid rgba(255,184,0,0.2);border-radius:8px;color:var(--warn);font-family:'IBM Plex Mono',monospace;font-size:11px;cursor:pointer">
        + Watchlist
      </button>` : `<div style="flex:1;padding:8px;background:rgba(255,184,0,0.04);border:1px solid rgba(255,184,0,0.1);border-radius:8px;color:var(--warn);font-family:'IBM Plex Mono',monospace;font-size:11px;text-align:center">
        👁 Watching
      </div>`}
    </div>

    <!-- AI Advice -->
    <div class="ai-advice-box">
      <div class="ai-advice-header">
        <span class="ai-label">🤖 AI Advice</span>
      </div>
      <button class="ai-get-btn" onclick="getAIAdvice('${ticker}',${price},${change},${scores.total},${earnings?earnings.days:99},'${analyst?analyst.bullishPct:50}')">
        ⚡ GET AI ADVICE — TAP TO ANALYSE
      </button>
    </div>

    <!-- Score -->
    <div class="score-section">
      <div class="section-label">
        Opportunity Score
        <span class="score-total" style="color:${scoreColor}">${scores.total}<span style="font-size:16px;color:var(--text3)">/85</span></span>
      </div>
      ${scoreRows.map(r => `
      <div class="score-row">
        <div>
          <div class="score-source">${r.label}</div>
          <div class="score-detail">${r.detail}</div>
        </div>
        <div class="score-track"><div class="score-fill" style="width:${(r.pts/r.max)*100}%;background:${r.color}"></div></div>
        <div class="score-pts" style="color:${r.color}">${r.pts}/${r.max}</div>
      </div>`).join('')}
    </div>

    <!-- Catalyst -->
    ${earnings ? `
    <div class="catalyst-section">
      <div class="section-label" style="margin-bottom:8px">Next Earnings <span style="color:var(--accent);font-size:9px">● REAL</span></div>
      <div class="catalyst-row">
        <div class="catalyst-icon">📊</div>
        <div class="catalyst-info">
          <div class="catalyst-date">Q${earnings.quarter} ${earnings.year} — ${earnings.date}</div>
          <div class="catalyst-urgency">${earnings.days <= 1 ? 'Tomorrow — very high urgency' : earnings.days <= 5 ? earnings.days+'d — high urgency' : earnings.days <= 14 ? earnings.days+'d — moderate urgency' : earnings.days+'d away'}</div>
        </div>
      </div>
    </div>` : ''}

    <!-- News -->
    <div class="news-section">
      <div class="section-label" style="margin-bottom:8px">Latest News <span style="color:var(--accent);font-size:9px">● LIVE</span></div>
      ${news.length > 0 ? news.map(n => `
      <div class="news-item">
        <div class="news-meta">
          <span class="news-time">${n.t}</span>
          <span class="news-sent ${n.s}">${n.s==='pos'?'Positive':n.s==='neg'?'Negative':'Neutral'}</span>
        </div>
        <div class="news-headline">${n.h}</div>
      </div>`).join('') : '<div style="font-size:12px;color:var(--text3);padding:8px 0">No recent news found</div>'}
    </div>`;
}

// ── AI ADVICE ──────────────────────────────────────────────────────────────────
async function getAIAdvice(ticker, price, change, score, earningsDays, bullishPct) {
  const btn = document.querySelector('.ai-get-btn');
  if(btn) {
    btn.textContent = '⟳ Analysing...';
    btn.disabled = true;
  }

  try {
    const prompt = `You are a stock market analyst. Analyse this stock and give brief advice.

Stock: ${ticker}
Current price: $${price}
Today's change: ${change.toFixed(2)}%
Opportunity score: ${score}/85
Days to next earnings: ${earningsDays === 99 ? 'Unknown' : earningsDays}
Analyst consensus: ${bullishPct}% bullish

Give a 2-3 sentence analysis in plain English that a beginner investor can understand. End with ONE word verdict: BUY, MONITOR, AVOID, or SELL. Format: [your analysis] VERDICT: [word]`;

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await response.json();
    const text = data.content?.[0]?.text || '';

    // Extract verdict
    const verdictMatch = text.match(/VERDICT:\s*(BUY|MONITOR|AVOID|SELL)/i);
    const verdict = verdictMatch ? verdictMatch[1].toUpperCase() : 'MONITOR';
    const analysis = text.replace(/VERDICT:.*$/i, '').trim();

    const verdictClass = verdict === 'BUY' ? 'verdict-buy' : verdict === 'MONITOR' ? 'verdict-monitor' : verdict === 'SELL' ? 'verdict-sell' : 'verdict-avoid';

    const box = document.querySelector('.ai-advice-box');
    if(box) {
      box.innerHTML = `
        <div class="ai-advice-header">
          <span class="ai-label">🤖 AI Advice</span>
          <span class="ai-verdict ${verdictClass}">${verdict}</span>
        </div>
        <div class="ai-text">${analysis}</div>`;
    }

  } catch(e) {
    const btn = document.querySelector('.ai-get-btn');
    if(btn) {
      btn.textContent = '⚡ GET AI ADVICE — TAP TO ANALYSE';
      btn.disabled = false;
    }
    console.error('AI advice error:', e);
  }
}

// ── MY STOCKS ──────────────────────────────────────────────────────────────────
function addToMyStocks(ticker, name, price) {
  if(myStocks.find(s => s.ticker === ticker)) return;

  // Simple add with defaults — user can set thresholds later
  myStocks.push({
    ticker,
    name,
    buyPrice: price,
    currentPrice: price,
    shares: 1,
    takeProfit: 20,  // default 20%
    stopLoss: 10,    // default 10%
    addedAt: new Date().toISOString()
  });

  localStorage.setItem('apexMyStocks', JSON.stringify(myStocks));
  updateCounts();

  // Show confirmation
  const btn = document.querySelector(`button[onclick*="addToMyStocks"]`);
  if(btn) btn.textContent = '✅ Added to My Stocks';
}

function addToWatchlist(ticker, name, price) {
  if(watchlist.find(s => s.ticker === ticker)) return;

  watchlist.push({ ticker, name, price, addedAt: new Date().toISOString() });
  localStorage.setItem('apexWatchlist', JSON.stringify(watchlist));
  updateCounts();

  const btn = document.querySelector(`button[onclick*="addToWatchlist"]`);
  if(btn) btn.textContent = '✅ Added to Watchlist';
}

async function renderMyStocks() {
  const el = document.getElementById('stockList');

  if(myStocks.length === 0) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">💼</div>
        <div class="empty-title">No Stocks Yet</div>
        <div class="empty-desc">Search for a stock and tap "Add to My Stocks" to track your positions here.</div>
      </div>`;
    return;
  }

  // Show loading then fetch real prices
  el.innerHTML = `<div class="loading-state"><div class="spinner"></div><div class="loading-text">UPDATING PRICES...</div></div>`;

  // Fetch current prices
  await Promise.all(myStocks.map(async s => {
    const q = await fetchQuote(s.ticker);
    if(q && q.c > 0) s.currentPrice = q.c;
  }));

  localStorage.setItem('apexMyStocks', JSON.stringify(myStocks));

  // Calculate portfolio totals
  let totalValue = 0, totalCost = 0;
  myStocks.forEach(s => {
    totalValue += s.currentPrice * s.shares;
    totalCost += s.buyPrice * s.shares;
  });
  const totalPnl = totalValue - totalCost;
  const totalPnlPct = totalCost > 0 ? (totalPnl/totalCost)*100 : 0;

  const pnlBar = `
    <div class="pnl-bar">
      <div class="pnl-cell">
        <div class="pnl-label">Portfolio Value</div>
        <div class="pnl-value">$${totalValue.toFixed(2)}</div>
      </div>
      <div class="pnl-cell">
        <div class="pnl-label">Total P&L</div>
        <div class="pnl-value" style="color:${totalPnl>=0?'var(--up)':'var(--down)'}">
          ${totalPnl>=0?'+':''}$${totalPnl.toFixed(2)}
        </div>
      </div>
      <div class="pnl-cell">
        <div class="pnl-label">Return</div>
        <div class="pnl-value" style="color:${totalPnlPct>=0?'var(--up)':'var(--down)'}">
          ${totalPnlPct>=0?'+':''}${totalPnlPct.toFixed(2)}%
        </div>
      </div>
    </div>`;

  const cards = myStocks.map((s, i) => {
    const pnl = (s.currentPrice - s.buyPrice) * s.shares;
    const pnlPct = ((s.currentPrice - s.buyPrice) / s.buyPrice) * 100;
    const up = pnl >= 0;

    // Check alerts
    let alertMsg = '';
    if(pnlPct >= s.takeProfit) alertMsg = `🎯 Take profit target hit (+${s.takeProfit}%)`;
    else if(pnlPct <= -s.stopLoss) alertMsg = `⚠️ Stop loss level reached (-${s.stopLoss}%)`;

    return `<div class="stock-card" id="card-${s.ticker}" onclick="selectStock('${s.ticker}','owned')" style="animation-delay:${i*0.04}s">
      <div class="card-heat owned"></div>
      <div class="card-main">
        <div class="card-top">
          <div class="card-ticker">${s.ticker}</div>
          <div class="card-badge badge-owned">OWNED</div>
          ${alertMsg ? `<div style="font-size:10px;color:var(--warn)">${alertMsg}</div>` : ''}
        </div>
        <div class="card-name">${s.name}</div>
        <div class="card-reason">Bought @ $${s.buyPrice.toFixed(2)} · ${s.shares} share${s.shares>1?'s':''}</div>
      </div>
      <div class="card-right">
        <div class="card-price">$${s.currentPrice.toFixed(2)}</div>
        <div class="card-pnl ${up?'up':'dn'}">${up?'+':''}$${pnl.toFixed(2)} (${up?'+':''}${pnlPct.toFixed(2)}%)</div>
      </div>
    </div>`;
  }).join('');

  el.innerHTML = pnlBar + cards;
}

// ── WATCHLIST ──────────────────────────────────────────────────────────────────
async function renderWatchlist() {
  const el = document.getElementById('stockList');

  if(watchlist.length === 0) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">👁</div>
        <div class="empty-title">Nothing Watching</div>
        <div class="empty-desc">Search for stocks and add them to your watchlist to monitor them here.</div>
      </div>`;
    return;
  }

  el.innerHTML = `<div class="loading-state"><div class="spinner"></div><div class="loading-text">UPDATING...</div></div>`;

  // Fetch prices
  await Promise.all(watchlist.map(async s => {
    const q = await fetchQuote(s.ticker);
    if(q && q.c > 0) { s.price = q.c; s.change = q.dp; }
  }));

  localStorage.setItem('apexWatchlist', JSON.stringify(watchlist));

  const cards = watchlist.map((s, i) => {
    const up = (s.change || 0) >= 0;
    return `<div class="stock-card" id="card-${s.ticker}" onclick="selectStock('${s.ticker}','watch')" style="animation-delay:${i*0.04}s">
      <div class="card-heat watch"></div>
      <div class="card-main">
        <div class="card-top">
          <div class="card-ticker">${s.ticker}</div>
          <div class="card-badge badge-watch">WATCHING</div>
        </div>
        <div class="card-name">${s.name}</div>
        <div class="card-reason">Added to watchlist</div>
      </div>
      <div class="card-right">
        <div class="card-price">$${(s.price||0).toFixed(2)}</div>
        <div class="card-change ${up?'up':'dn'}">${up?'+':''}${(s.change||0).toFixed(2)}%</div>
        <div style="font-size:10px;color:var(--text3);margin-top:4px;cursor:pointer" onclick="removeFromWatchlist('${s.ticker}',event)">✕ Remove</div>
      </div>
    </div>`;
  }).join('');

  el.innerHTML = cards;
}

function removeFromWatchlist(ticker, e) {
  e.stopPropagation();
  watchlist = watchlist.filter(s => s.ticker !== ticker);
  localStorage.setItem('apexWatchlist', JSON.stringify(watchlist));
  updateCounts();
  renderWatchlist();
}

// ── LOAD STOCK FROM SEARCH ─────────────────────────────────────────────────────
async function loadStock(ticker, name) {
  document.getElementById('searchResults').classList.remove('open');
  document.getElementById('searchInput').value = '';

  // Add to watchlist automatically
  if(!watchlist.find(s => s.ticker === ticker)) {
    watchlist.push({ ticker, name, price: 0, change: 0, addedAt: new Date().toISOString() });
    localStorage.setItem('apexWatchlist', JSON.stringify(watchlist));
    updateCounts();
  }

  // Switch to watchlist tab and select
  switchTab('watchlist');
  await selectStock(ticker, 'watch');
}

// ── DETAIL PANEL OPEN/CLOSE ────────────────────────────────────────────────────
function openDetail() {
  document.getElementById('detailPanel').classList.add('open');
  document.getElementById('detailOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDetail() {
  document.getElementById('detailPanel').classList.remove('open');
  document.getElementById('detailOverlay').classList.remove('open');
  document.body.style.overflow = '';
  selectedTicker = null;
  document.querySelectorAll('.stock-card').forEach(c => c.classList.remove('selected'));
}

// On desktop, detail panel is always visible — no need to open/close
function isDesktop() { return window.innerWidth >= 768; }

// Override openDetail for desktop
const _openDetail = openDetail;
window.openDetail = function() {
  if(!isDesktop()) _openDetail();
};

// ── INIT ───────────────────────────────────────────────────────────────────────
updateCounts();
</script>
</body>
</html>
